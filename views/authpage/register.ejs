            { code: '+998', country: 'Uzbekistan' }
        ],
        get isEmailValid() { return /^\S+@\S+\.\S+$/.test(this.email) },
        get isPasswordValid() { return this.password.length >= 8 },
        get doPasswordsMatch() { return this.password === this.confirmPassword },
        get isMobileValid() { return this.mobileNumber.length >= 10 }
     }">
    
    <div class="hidden md:flex md:w-1/2 bg-green-600 p-12 flex-col justify-between text-white">
        <div>
            <div class="flex items-center gap-2 mb-12">
                <i class="fab fa-whatsapp text-3xl"></i>
                <span class="text-2xl font-bold tracking-tight">WapiSaaS</span>
            </div>
            <h1 class="text-5xl font-extrabold leading-tight mb-6">Connect with your customers where they are.</h1>
            <ul class="space-y-6">
                <li class="flex items-start gap-4">
                    <div class="bg-green-500 p-1 rounded-full"><i class="fas fa-check text-xs"></i></div>
                    <p class="text-lg opacity-90">Official WhatsApp Cloud API Integration</p>
                </li>
                <li class="flex items-start gap-4">
                    <div class="bg-green-500 p-1 rounded-full"><i class="fas fa-check text-xs"></i></div>
                    <p class="text-lg opacity-90">No-code Chatbot Builder included</p>
                </li>
                <li class="flex items-start gap-4">
                    <div class="bg-green-500 p-1 rounded-full"><i class="fas fa-check text-xs"></i></div>
                    <p class="text-lg opacity-90">Scalable for Enterprise high-volume messaging</p>
                </li>
            </ul>
        </div>
        <div class="bg-green-700/50 p-6 rounded-2xl border border-white/10">
            <p class="italic opacity-80 mb-4">"WapiSaaS helped us increase our customer engagement by 300% in just two months."</p>
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-gray-200 rounded-full"></div>
                <div>
                    <p class="font-bold text-sm">Rahul Sharma</p>
                    <p class="text-xs opacity-60">CEO, TechFlow India</p>
                </div>
            </div>
        </div>
    </div>

    <div class="w-full md:w-1/2 flex items-center justify-center p-8 md:p-16 bg-gray-50">
        <div class="max-w-md w-full">
            <div class="mb-10 text-center md:text-left">
                <h2 class="text-3xl font-extrabold text-gray-900">Create your account</h2>
                <p class="text-gray-500 mt-2">Join 1,000+ businesses automating WhatsApp.</p>
            </div>

            <div class="flex flex-col gap-3 mb-8">
                <a href="/auth/google" class="flex items-center justify-center gap-3 w-full py-3 border border-gray-300 rounded-xl bg-white hover:bg-gray-50 transition font-semibold text-gray-700">
                    <img src="https://www.svgrepo.com/show/355037/google.svg" class="w-5 h-5" alt="Google">
                    Continue with Google
                </a>
            </div>

            <div class="relative flex items-center py-4 mb-6">
                <div class="flex-grow border-t border-gray-200"></div>
                <span class="flex-shrink mx-4 text-gray-400 text-xs uppercase tracking-widest">Or use email</span>
                <div class="flex-grow border-t border-gray-200"></div>
            </div>

            <form action="/register" method="POST" class="space-y-5">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Business Name</label>
                    <input type="text" name="name" required class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition" placeholder="Acme Corp">
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Work Email</label>
                    <div class="relative">
                        <input type="email" name="email" x-model="email" required class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition" placeholder="you@company.com">
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center" x-show="email.length > 0">
                            <i class="fas" :class="isEmailValid ? 'fa-check-circle text-green-500' : 'fa-times-circle text-red-400'"></i>
                        </div>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Create Password</label>
                    <div class="relative">
                        <input :type="showPassword ? 'text' : 'password'" name="password" x-model="password" required class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition" placeholder="••••••••">
                        <button type="button" @click="showPassword = !showPassword" class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-green-600 transition">
                            <i class="fas" :class="showPassword ? 'fa-eye-slash' : 'fa-eye'"></i>
                        </button>
                    </div>
                    <div class="mt-2 flex gap-1">
                        <template x-for="i in 4">
                            <div class="h-1 flex-1 rounded-full" :class="password.length >= (i*2) ? 'bg-green-500' : 'bg-gray-200'"></div>
                        </template>
                    </div>
                    <p class="text-[11px] mt-1 text-gray-500" :class="isPasswordValid ? 'text-green-600' : ''">Minimum 8 characters required.</p>
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Confirm Password</label>
                    <div class="relative">
                        <input :type="showConfirmPassword ? 'text' : 'password'" name="confirmPassword" x-model="confirmPassword" required class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition" placeholder="••••••••">
                        <button type="button" @click="showConfirmPassword = !showConfirmPassword" class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-green-600 transition">
                            <i class="fas" :class="showConfirmPassword ? 'fa-eye-slash' : 'fa-eye'"></i>
                        </button>
                    </div>
                    <p class="text-[11px] mt-1 text-gray-500" :class="doPasswordsMatch && confirmPassword.length > 0 ? 'text-green-600' : ''">
                        <span x-show="!doPasswordsMatch && confirmPassword.length > 0" class="text-red-500">Passwords do not match</span>
                        <span x-show="doPasswordsMatch && confirmPassword.length > 0" class="text-green-600">Passwords match</span>
                    </p>
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Mobile Number</label>
                    <div class="flex gap-2">
                        <select name="countryCode" x-model="countryCode" required class="px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition bg-white">
                            <template x-for="country in countryCodes" :key="country.code">
                                <option :value="country.code" x-text="`${country.code} ${country.country}`"></option>
                            </template>
                        </select>
                        <input type="tel" name="mobileNumber" x-model="mobileNumber" required class="flex-1 px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition" placeholder="10-15 digits">
                    </div>
                    <p class="text-[11px] mt-1 text-gray-500" :class="isMobileValid ? 'text-green-600' : ''">Enter mobile number with 10-15 digits (excluding country code)</p>
                </div>

                <div class="flex items-start gap-3 py-2">
                    <input type="checkbox" x-model="agreeTerms" id="terms" required class="mt-1 h-4 w-4 text-green-600 border-gray-300 rounded focus:ring-green-500">
                    <label for="terms" class="text-sm text-gray-500 leading-tight">
                        I agree to the <a href="/terms" class="text-green-600 font-semibold underline">Terms of Service</a> and <a href="/privacy" class="text-green-600 font-semibold underline">Privacy Policy</a>.
                    </label>
                </div>

                <button type="submit" 
                        :disabled="!isEmailValid || !isPasswordValid || !doPasswordsMatch || !isMobileValid || !agreeTerms"
                        class="w-full bg-green-600 text-white font-bold py-4 rounded-xl hover:bg-green-700 shadow-xl shadow-green-200 transition-all transform hover:-translate-y-1 disabled:opacity-50 disabled:transform-none disabled:shadow-none">
                    Create Account
                </button>
            </form>

            <p class="text-center mt-8 text-sm text-gray-600">
                Already have an account? <a href="/auth/login" class="text-green-600 font-bold hover:underline">Sign in</a>
            </p>
        </div>
    </div>
</div>

<script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
</body>
</html>