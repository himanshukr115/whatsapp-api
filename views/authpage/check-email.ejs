<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify Your Email - WhatsApp SaaS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; display: flex; align-items: center; min-height: 100vh; }
        .card { border: none; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
        .btn-whatsapp { background-color: #25D366; color: white; border-radius: 50px; }
    </style>
</head>
<body>
    <div class="container text-center">
        <div class="card p-5 mx-auto" style="max-width: 500px;">
            <div class="mb-4">
                <i class="bi bi-envelope-check text-success" style="font-size: 4rem;"></i>
            </div>
            <h2 class="mb-3">Confirm your email</h2>
            <p class="text-muted">We've sent a verification link to <strong><%= email %></strong>. Please check your inbox and click the link to activate your account.</p>
            <hr>
            <p class="small text-muted">Didn't receive the email? Check your spam folder.</p>
            <a href="/auth/login" class="btn btn-outline-secondary mt-3">Back to Login</a>
        </div>
    </div>
</body>
</html>